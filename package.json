{
  "name": "soul-mcp",
  "version": "4.0.0",
  "description": "A soul for your AI: trusted memory (provenance, ledger, policy-in-code) plus a thinking loop \u2014 the Denkpartner protocol \u2014 that turns any model into the memory's reasoning engine and feeds the model its own calibration record. Local-first, one MCP server.",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "soul-mcp": "dist/src/index.js",
    "soul": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/src/index.js serve",
    "test": "npm run build && node --test \"test/*.test.mjs\"",
    "prepublishOnly": "npm run test"
  },
  "keywords": [
    "mcp",
    "ai",
    "memory",
    "soul",
    "claude",
    "persistent-memory",
    "ai-memory",
    "model-context-protocol",
    "event-sourcing",
    "provenance",
    "context-engineering",
    "local-first"
  ],
  "author": "Miguel <miguel@nextool.app>",
