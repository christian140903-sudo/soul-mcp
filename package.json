{
  "name": "soul-mcp",
  "version": "4.0.1",
  "description": "Local-first persistent memory and an auditable runtime for Claude, Cursor, Windsurf and any MCP client. Provenance, conflict handling, receipts and no cloud.",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "soul-mcp": "dist/src/index.js",
    "soul": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/src/index.js serve",
    "test": "npm run build && node --test \"test/*.test.mjs\"",
    "prepack": "npm run build",
    "smoke:pack": "node scripts/release-smoke.mjs",
    "prepublishOnly": "npm run test"
  },
  "keywords": [
    "mcp",
    "ai",
    "memory",
    "soul",
    "claude",
    "persistent-memory",
    "ai-memory",
    "model-context-protocol",
    "event-sourcing",
    "provenance",
    "context-engineering",
    "local-first",
    "claude-code",
    "cursor",
    "windsurf",
    "mcp-server",
    "ai-agent-memory",
    "sqlite"
  ],
  "author": "Christian Bucher",
  "contributors": [
    "Miguel (AI systems co-builder, under human review)"
  ],
  "license": "MIT",
  "files": [
    "dist/src",
    "server.json",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/christian140903-sudo/soul-mcp"
  },
  "bugs": {
    "url": "https://github.com/christian140903-sudo/soul-mcp/issues"
  },
  "homepage": "https://christian140903-sudo.github.io/#systems",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.6.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "mcpName": "io.github.christian140903-sudo/soul-mcp"
}
